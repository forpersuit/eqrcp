{
  "name": "eqt-feedback-api",
  "version": "1.0.0",
  "description": "Serverless Feedback & Diagnostics Backend for EQT on Cloudflare",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create eqt-feedback-db",
    "db:init:local": "wrangler d1 execute eqt-feedback-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute eqt-feedback-db --remote --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240101.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.22.0"
  }
}
