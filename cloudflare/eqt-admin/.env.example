# DRM API 根路径（无尾斜杠）
# 本地 secret 模式: http://127.0.0.1:8787
# 生产 Access 模式: 留空（同源 /api 反代到 lic.eqt.net.im）
# 生产无 Access 过渡: https://lic.eqt.net.im
VITE_API_BASE=http://127.0.0.1:8787

# secret = 本地/密钥登录；access = Cloudflare Access（admin.eqt.net.im 默认 access）
# VITE_ADMIN_AUTH_MODE=secret

# Access 登出（team domain，无 https://）
# VITE_CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com

# 完整配置: docs/admin/cloudflare-access-setup.md
